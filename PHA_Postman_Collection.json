{
  "info": {
    "name": "PHA API & Webhook Testing",
    "description": "Koleksi Postman untuk testing backend PHA dan n8n Webhook",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "n8n Webhooks",
      "item": [
        {
          "name": "Test PHA Chat Webhook (n8n)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-test-123\",\n  \"sessionId\": \"session-test-001\",\n  \"message\": \"Halo, saya sedang merasa cemas hari ini. Ada saran?\",\n  \"history\": [],\n  \"profileContext\": \"[Konteks Pengguna: Nama=Budi, Usia=25]\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://n8n.alstore.space/webhook-test/pha-chat",
              "protocol": "https",
              "host": [
                "n8n",
                "alstore",
                "space"
              ],
              "path": [
                "webhook-test",
                "pha-chat"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
