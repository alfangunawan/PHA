{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["prisma/seed.ts", "scripts", "node_modules", "dist", "tests", "src/**/__tests__/**", "src/**/*.test.ts"]
}
