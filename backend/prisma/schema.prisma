generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  GAMIFICATION_ADMIN
  MINDFULNESS_ADMIN
}

enum MeditationCategory {
  sleep
  focus
  anxiety
  morning
  general
}

enum ContentSource {
  youtube
  tiktok
  other
}

enum ContentFormat {
  landscape
  vertical
}

enum AnxietyLevel {
  rendah
  sedang
  tinggi
  risiko_tinggi
}

enum ActivityType {
  BREATHING
  MEDITATION
  EDUCATION_CONTENT
  AUDIO_CONTENT
  JOURNAL_ENTRY
  WORD_PUZZLE
  TETRIS
}

enum GameType {
  WORD_PUZZLE
  TETRIS
}

enum GameStatus {
  started
  completed
  abandoned
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  passwordHash          String
  role                  Role                   @default(USER)
  createdAt             DateTime               @default(now())
  profile               UserProfile?
  sessions              ChatSession[]
  conversations         Conversation[]
  gad7Results           Gad7Result[]
  chatbotStates         ChatbotSessionState[]
  breathingLogs         BreathingLog[]
  meditationLogs        MeditationLog[]
  educationContents     EducationContent[]     @relation("EducationAdmin")
  audioContents         AudioContent[]         @relation("AudioAdmin")
  journalEntries        JournalEntry[]
  positiveWords         PersonalPositiveWord[]
  gameSessions          GameSession[]
  gamification          UserGamification?
  rewardEvents          RewardEvent[]
  rewardRulesCreated    RewardRule[]           @relation("RewardRuleAdmin")
}

model UserProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  displayName String
  age         Int?
  gender      String?
  language    String  @default("id")
  bio         String?
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  startedAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sender    String
  message   String
  timestamp DateTime    @default(now())
}

model Conversation {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id")
  sessionId String    @map("session_id")
  role      String
  content   String
  cbtPhase  String?   @default("ventilasi") @map("cbt_phase")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "idx_conv_session")
  @@index([userId, createdAt(sort: Desc)], map: "idx_conv_user_created")
  @@map("conversations")
}

model Gad7Result {
  id       Int      @id @default(autoincrement())
  userId   String   @map("user_id")
  score    Int
  severity String
  answers  Json?
  takenAt  DateTime @default(now()) @map("taken_at") @db.Timestamptz(6)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt(sort: Desc)], map: "idx_gad7_user_taken")
  @@map("gad7_results")
}

model ChatbotSessionState {
  sessionId              String   @id @map("session_id")
  userId                 String   @map("user_id")
  currentPhase           String   @default("ventilasi") @map("current_phase")
  problemCount           Int      @default(0) @map("problem_count")
  activeProblemNum       Int      @default(1) @map("active_problem_num")
  deferredProblemSummary String?  @map("deferred_problem_summary")
  phaseTurnCount         Int      @default(0) @map("phase_turn_count")
  homeworkLog            Json     @default("[]") @map("homework_log")
  sessionComplete        Boolean  @default(false) @map("session_complete")
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chatbot_session_state")
}

model BreathingTechnique {
  id              String         @id @default(uuid())
  name            String
  description     String?
  inhaleDuration  Int
  holdDuration    Int            @default(0)
  exhaleDuration  Int
  holdAfterExhale Int            @default(0)
  cycles          Int            @default(4)
  colorTheme      String         @default("#A8C5DA")
  icon            String         @default("wind")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  logs            BreathingLog[]
}

model BreathingLog {
  id              String             @id @default(uuid())
  userId          String
  techniqueId     String
  duration        Int
  cyclesCompleted Int                @default(0)
  completedAt     DateTime           @default(now())
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  technique       BreathingTechnique @relation(fields: [techniqueId], references: [id], onDelete: Cascade)
}

model MeditationSession {
  id              String              @id @default(uuid())
  title           String
  description     String?
  category        MeditationCategory  @default(general)
  audioUrl        String?
  thumbnailUrl    String?
  durationOptions Json
  colorTheme      String              @default("#C9B8E8")
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  logs            MeditationLog[]
}

model MeditationLog {
  id          String            @id @default(uuid())
  userId      String
  sessionId   String
  duration    Int
  completed   Boolean           @default(false)
  completedAt DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     MeditationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model EducationContent {
  id               String        @id @default(uuid())
  title            String
  description      String?
  source           ContentSource @default(youtube)
  url              String
  thumbnailUrl     String?
  category         String        @default("general")
  tags             Json?
  format           ContentFormat @default(landscape)
  createdByAdminId String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdByAdmin   User?         @relation("EducationAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
}

model AudioContent {
  id               String   @id @default(uuid())
  title            String
  fileUrl          String
  category         String   @default("general")
  duration         Int?
  description      String?
  createdByAdminId String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  createdByAdmin   User?    @relation("AudioAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
}

model JournalEntry {
  id             String       @id @default(uuid())
  userId         String
  title          String?
  content        String
  normalizedText String?
  anxietyLevel   AnxietyLevel @default(rendah)
  highRisk       Boolean      @default(false)
  analysis       Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PersonalPositiveWord {
  id              String   @id @default(uuid())
  userId          String
  word            String
  category        String?
  sourceJournalId String?
  weight          Int      @default(1)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, lastUsedAt])
}

model GameSession {
  id          String     @id @default(uuid())
  userId      String
  gameType    GameType
  status      GameStatus @default(started)
  score       Int        @default(0)
  durationSec Int?
  payload     Json?
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gameType, createdAt])
}

model UserGamification {
  id        String   @id @default(uuid())
  userId    String   @unique
  xp        Int      @default(0)
  points    Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RewardRule {
  id               String       @id @default(uuid())
  activityType     ActivityType @unique
  xp               Int          @default(0)
  points           Int          @default(0)
  isActive         Boolean      @default(true)
  createdByAdminId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  createdByAdmin   User?        @relation("RewardRuleAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
}

model RewardEvent {
  id             String       @id @default(uuid())
  userId         String
  activityType   ActivityType
  sourceId       String?
  idempotencyKey String       @unique
  xp             Int
  points         Int
  metadata       Json?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, activityType])
  @@index([userId, createdAt])
}
